{{#if retryLogic}}
class TestRetryLogic:
    """Test retry logic"""
    
    @pytest.mark.asyncio
    async def test_retry_on_failure(self, mock_httpx_client):
        """Test that requests are retried on failure"""
        # Mock to fail twice then succeed
        mock_response = Mock()
        mock_response.json.return_value = {"status": "success"}
        mock_response.raise_for_status = Mock()
        
        mock_httpx_client.request = AsyncMock(
            side_effect=[
                httpx.HTTPError("Error 1"),
                httpx.HTTPError("Error 2"),
                mock_response
            ]
        )
        
        # Test with first tool
        {{#if tools}}
        {{#with (lookup tools 0)}}
        {{#if ../usePydantic}}
        from main import {{capitalize name}}Input
        test_input = {{capitalize name}}Input(
            {{#each inputSchema.properties}}
            {{@key}}={{#if (eq type 'string')}}'test-value'{{/if}}{{#if (eq type 'number')}}123{{/if}}{{#if (eq type 'boolean')}}True{{/if}}{{#unless @last}},{{/unless}}
            {{/each}}
        )
        result = await main.{{name}}(test_input)
        {{else}}
        result = await main.{{name}}(
            {{#each inputSchema.properties}}
            {{@key}}={{#if (eq type 'string')}}'test-value'{{/if}}{{#if (eq type 'number')}}123{{/if}}{{#if (eq type 'boolean')}}True{{/if}}{{#unless @last}},{{/unless}}
            {{/each}}
        )
        {{/if}}
        
        # Should eventually succeed
        assert result is not None
        assert mock_httpx_client.request.call_count == 3
        {{/with}}
        {{/if}}
{{/if}}

