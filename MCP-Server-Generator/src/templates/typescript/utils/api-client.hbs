/**
 * API Client for {{name}}
 */
import axios, { AxiosInstance, AxiosRequestConfig } from 'axios';
{{#if auth}}
import * as dotenv from 'dotenv';

dotenv.config();
{{/if}}

export class APIClient {
  private client: AxiosInstance;
  private baseURL: string;

  constructor() {
    this.baseURL = '{{baseUrl}}';
    this.client = axios.create({
      baseURL: this.baseURL,
      timeout: 30000,
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'User-Agent': '{{name}}-MCP-Client/1.0.0',
      },
      {{#if retryLogic}}
      // Retry configuration
      validateStatus: (status) => status < 500,
      {{/if}}
    });

    {{#if auth}}
    this.setupAuth();
    {{/if}}
    {{#if retryLogic}}
    this.setupRetry();
    {{/if}}
  }

  {{#if auth}}
  private setupAuth(): void {
    {{#if (eq auth.type "apiKey")}}
    const apiKey = process.env.API_KEY;
    if (!apiKey) {
      throw new Error('API_KEY environment variable is required');
    }
    this.client.defaults.headers.common['{{auth.headerName}}'] = apiKey;
    {{/if}}
    {{#if (eq auth.type "bearer")}}
    const token = process.env.API_TOKEN;
    if (!token) {
      throw new Error('API_TOKEN environment variable is required');
    }
    this.client.defaults.headers.common['Authorization'] = `Bearer ${token}`;
    {{/if}}
    {{#if (eq auth.type "basic")}}
    const username = process.env.API_USERNAME;
    const password = process.env.API_PASSWORD;
    if (!username || !password) {
      throw new Error('API_USERNAME and API_PASSWORD environment variables are required');
    }
    this.client.defaults.auth = { username, password };
    {{/if}}
  }
  {{/if}}

  {{#if retryLogic}}
  private setupRetry(): void {
    this.client.interceptors.response.use(
      (response) => response,
      async (error) => {
        const config = error.config as AxiosRequestConfig & { _retry?: number };
        
        if (!config || !error.response) {
          return Promise.reject(error);
        }

        config._retry = config._retry || 0;
        
        if (config._retry >= 3) {
          return Promise.reject(error);
        }

        if (error.response.status >= 500 || error.response.status === 429) {
          config._retry += 1;
          const delay = Math.pow(2, config._retry) * 1000;
          await new Promise(resolve => setTimeout(resolve, delay));
          return this.client(config);
        }

        return Promise.reject(error);
      }
    );
  }
  {{/if}}

  async get<T = any>(path: string, params?: Record<string, any>): Promise<T> {
    const response = await this.client.get<T>(path, { params });
    return response.data;
  }

  async post<T = any>(path: string, data?: any): Promise<T> {
    const response = await this.client.post<T>(path, data);
    return response.data;
  }

  async put<T = any>(path: string, data?: any): Promise<T> {
    const response = await this.client.put<T>(path, data);
    return response.data;
  }

  async delete<T = any>(path: string): Promise<T> {
    const response = await this.client.delete<T>(path);
    return response.data;
  }
}