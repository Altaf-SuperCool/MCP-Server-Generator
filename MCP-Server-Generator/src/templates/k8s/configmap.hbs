apiVersion: v1
kind: ConfigMap
metadata:
  name: {{serverName}}-config
  labels:
    app: {{serverName}}
data:
  API_BASE_URL: "{{apiBaseUrl}}"
  NODE_ENV: "production"
  {{#if useHttpTransport}}
  PORT: "{{#if (eq language "typescript")}}3000{{else}}8000{{/if}}"
  {{/if}}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{serverName}}-secrets
  labels:
    app: {{serverName}}
type: Opaque
stringData:
  {{#if auth}}
  {{#if (eq auth.type "apiKey")}}
  api-key: "YOUR_API_KEY_HERE"
  {{/if}}
  {{#if (eq auth.type "bearer")}}
  bearer-token: "YOUR_BEARER_TOKEN_HERE"
  {{/if}}
  {{#if (eq auth.type "oauth2")}}
  access-token: "YOUR_ACCESS_TOKEN_HERE"
  {{/if}}
  {{#if (eq auth.type "basic")}}
  username: "YOUR_USERNAME_HERE"
  password: "YOUR_PASSWORD_HERE"
  {{/if}}
  {{else}}
  # No authentication configured
  placeholder: "none"
  {{/if}}